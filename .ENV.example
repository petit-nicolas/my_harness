# ============================================================================
# Harness 项目环境变量模板
# ----------------------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .ENV：    cp .ENV.example .ENV
#   2. 把下面占位值替换为真 key
#   3. .ENV 已在 .gitignore 中，**禁止 commit**
#
# 安全约束：
#   - 任何贴 token 到 PR / Issue / 群聊的行为都视为泄漏，须立即在控制台吊销
#   - 本文件（.ENV.example）只放占位符，绝不放真 key
# ============================================================================


# --- 阿里千问 API Key ----------------------------------------------------
# 用途：Harness 主线 Runner（src/client.py）调用 qwen-plus / qwen-max
# 申请：https://dashscope.console.aliyun.com/apiKey
# 必需性：所有分支必需
Ali_API_KEY=sk-REPLACE_ME_WITH_REAL_DASHSCOPE_KEY


# --- MinerU API Key ------------------------------------------------------
# 用途：vertical-industry 分支物理子项目 Builder 的教材解析
#       （src/phy/tools/mineru.py，详见 .cursor/rules/mineru-tool.mdc）
# 申请：https://mineru.net  → 控制台 → API Token
# 必需性：仅 vertical-industry 分支 V1 及以后必需
# 配额：免费账号每日 2000 页解析；超出后切 --lightweight 或次日重试
# 模式：mineru.py 仅在 builder mode 下使用，runner（学生侧）不会触发
MinerU_API_KEY=eyJ_REPLACE_ME_WITH_REAL_MINERU_JWT_TOKEN


# ============================================================================
# 自检：填好后运行下面命令验证（应当不报"未找到 Key"）。
# 自检会拒绝任何包含 REPLACE_ME 字样的占位符。
#
#   python -c "from dotenv import load_dotenv; load_dotenv('.ENV'); \
#              import os; \
#              ali = os.environ.get('Ali_API_KEY',''); \
#              mu  = os.environ.get('MinerU_API_KEY',''); \
#              assert ali.startswith('sk-') and 'REPLACE_ME' not in ali, 'Ali_API_KEY 缺失/未替换'; \
#              assert len(mu) > 50 and 'REPLACE_ME' not in mu, 'MinerU_API_KEY 缺失/未替换'; \
#              print('OK: 两个 key 都已加载且非占位符')"
# ============================================================================
